  <body
    class="bg-[#f2ead4] text-slate-900 antialiased min-h-screen flex flex-col"
  >
    <Navbar />

    <main class="grow w-full max-w-7xl mx-auto sm:px-6 lg:px-8">
      <slot />
    </main>
    {/* 2. Inyectamos el Footer estático */}
    <Footer />
  </body>
</html>
