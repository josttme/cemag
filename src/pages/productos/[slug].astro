---
// src/pages/productos/[id].astro
import Layout from '@layouts/Layout.astro';
import { products } from '@lib/data';
import ProductConfigurator from '@components/react/ProductConfigurator';

// Ahora Astro mapeará TODOS los productos del array real
export async function getStaticPaths() {
  return products.map((product) => ({
    // EL FIX: Cambiamos 'id' por 'slug'
    params: { slug: product.slug },
    props: { product },
  }));
}
const { product } = Astro.props;
---

<Layout title={`${product.name} - Cemag`} description={product.description}>
  <main class="w-full pt-8 pb-16 lg:py-12">
    <ProductConfigurator client:load product={product} />
  </main>
</Layout>
