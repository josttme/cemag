---
// src/pages/index.astro
import Layout from '@layouts/Layout.astro';
import ProductCard from '@components/astro/ProductCard.astro';
import HeroCarousel from '@components/react/HeroCarousel';
import CategoryNav from '@components/astro/CategoryNav.astro';

// 1. Importamos la base de datos de inventario
import { products } from '@lib/data';
// 2. Importamos la lógica de marketing/CMS
import { getActiveHeroSlides, categoryNavData } from '@lib/storefront';

// 3. Obtenemos los banners promocionales activos.
// En el futuro, esto puede ser un "await fetch('tu-api')" y el HTML no cambiará.
const heroSlides = getActiveHeroSlides();
---

<Layout
  title="CEMAG - Indumentaria y Calzado"
  description="Catálogo de remeras, pantalones y calzado con moldería de alta calidad."
>
  {/* SECCIÓN 1: El Gancho (Marketing) */}
  <section>
    <HeroCarousel slides={heroSlides} client:load />
  </section>

  {/* SECCIÓN 2: Categorías Visuales */}
  <section>
    <CategoryNav categories={categoryNavData} />
  </section>

  {/* SECCIÓN 3: El Catálogo (Inventario) */}
  <section class="py-10">
    <div class="flex justify-between items-end mb-6 px-1">
      <h2 class="text-2xl font-bold text-slate-900">Nuevos Ingresos</h2>
      <a
        href="/colecciones/todas"
        class="text-sm font-medium text-slate-500 hover:text-slate-900 transition-colors"
      >
        Ver todo &rarr;
      </a>
    </div>

    <div
      class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-3 gap-y-10"
    >
      {
        // Iteramos sobre nuestra base de datos real
        products.map((product) => <ProductCard product={product} />)
      }
    </div>
  </section>
</Layout>
