---
// src/components/astro/ProductCard.astro
import type { Product } from '@lib/data';

interface Props {
  product: Product;
}

const { product } = Astro.props;

// 1. Obtenemos la imagen frontal del primer color disponible
const mainImage = product.variants[0]?.images[0];
// 2. Generamos la URL amigable para el SEO
const productUrl = `/productos/${product.slug}`;
---

<a href={productUrl} class="group flex flex-col gap-3 cursor-pointer">
  {/* Contenedor de la Imagen con Aspect Ratio de Indumentaria (4:5) */}
  <div
    class="relative aspect-4/5 overflow-hidden rounded-xl bg-[#f6f6f6] border border-slate-100"
  >
    {
      mainImage && (
        <img
          src={mainImage.url}
          alt={mainImage.alt}
          class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
          loading="lazy"
        />
      )
    }
  </div>

  {/* Información de la Prenda */}
  <div class="flex flex-col gap-1 px-1">
    <div class="flex justify-between items-start gap-2">
      <h3 class="text-sm md:text-base font-medium text-slate-900 line-clamp-1">
        {product.name}
      </h3>
      <p
        class="text-sm md:text-base font-medium text-slate-900 whitespace-nowrap"
      >
        ${product.price.toLocaleString('es-AR')}
      </p>
    </div>

    {/* Mostramos el textil para aportar valor */}
    <p class="text-xs text-slate-500 line-clamp-1">
      {product.details.fabric}
    </p>

    {/* Swatches (Círculos de Colores Disponibles) */}
    <div class="flex items-center gap-1.5 mt-2">
      {
        product.variants.map((variant) => (
          <div
            class="w-4 h-4 rounded-full border border-slate-200 shadow-sm"
            style={`background-image: url(${variant.swatchUrl}); background-size: cover;`}
            title={variant.colorName}
          />
        ))
      }
      {
        product.variants.length > 1 && (
          <span class="text-[10px] text-slate-400 ml-1">
            {product.variants.length} colores
          </span>
        )
      }
    </div>
  </div>
</a>
