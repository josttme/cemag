---
// src/layouts/Layout.astro
import Navbar from '@/components/astro/Navbar.astro';
import Footer from '@/components/astro/Footer.astro';

interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = 'Cemag - La mejor tienda online de indumentaria y calzado.',
} = Astro.props;
import '@/styles/global.css';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
  </head>

  <body
    class="bg-[#f2ead4] text-slate-900 antialiased min-h-screen flex flex-col"
  >
    <Navbar />

    <main class="grow w-full max-w-7xl mx-auto sm:px-6 lg:px-8">
      <slot />
    </main>
    {/* 2. Inyectamos el Footer estático */}
    <Footer />
  </body>
</html>
